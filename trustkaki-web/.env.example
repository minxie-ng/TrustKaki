# TrustKaki LLM Configuration
# Copy this file to .env.local and fill in your values.
#
# The provider uses an OpenAI-compatible Chat Completions API format.
# This works with OpenAI, Azure OpenAI, Together AI, Tencent Cloud,
# and any provider that implements the OpenAI API format.

# Required: Your LLM API key
TRUSTKAKI_LLM_API_KEY=

# Optional: Base URL for the LLM API (defaults to OpenAI)
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   Together AI:  https://api.together.xyz/v1
#   Tencent Cloud: https://api.hunyuan.cloud.tencent.com/v1
# TRUSTKAKI_LLM_BASE_URL=https://api.openai.com/v1

# Optional: Model name (defaults to gpt-4o-mini)
# Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo, llama-3.1-70b-instruct
# TRUSTKAKI_LLM_MODEL=gpt-4o-mini

# Supabase Persistence
# Browser-safe public values:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Never expose this in client code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# Meta WhatsApp Cloud API.
# Server-only. Never expose these in client code or NEXT_PUBLIC_* vars.
# Meta-generated temporary access tokens are development-only; deployed use
# needs an appropriate durable Meta credential configured server-side.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v23.0
META_APP_SECRET=
WHATSAPP_INTERNAL_PROCESSOR_SECRET=
ENABLE_WHATSAPP_DEV_SIMULATOR=false

# Demo phone mapping. Use digits or +E.164; TrustKaki normalizes for lookup.
TRUSTKAKI_DEMO_SENIOR_PHONE=
