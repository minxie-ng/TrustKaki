# TrustKaki environment template.
# Copy this file to .env.local for local development, or configure these values
# in Vercel Project Settings. Do not commit real secret values.

# Required for Judge View: OpenAI-compatible LLM provider.
# WorkBuddy can later replace or extend this provider through src/lib/agents/provider.ts.
TRUSTKAKI_LLM_API_KEY=
TRUSTKAKI_LLM_BASE_URL=https://api.openai.com/v1
TRUSTKAKI_LLM_MODEL=gpt-4o-mini
TRUSTKAKI_LLM_TIMEOUT_MS=30000

# Required for Judge View: Supabase persistence.
# NEXT_PUBLIC_* values are browser-visible by design. Do not put secrets there.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required only for live WhatsApp.
# These are server-side secrets/configuration. Never expose them in client code
# or NEXT_PUBLIC_* variables. Meta temporary access tokens are development-only;
# production should use an appropriate durable Meta credential.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v23.0
META_APP_SECRET=
WHATSAPP_INTERNAL_PROCESSOR_SECRET=

# Demo phone mapping for live WhatsApp senior lookup.
TRUSTKAKI_DEMO_SENIOR_PHONE=

# Required only for live Telegram demo continuity.
# These values are server-side secrets. TELEGRAM_WEBHOOK_SECRET is supplied to
# Telegram during setWebhook and must contain only A-Z, a-z, 0-9, underscore,
# and hyphen characters.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_INTERNAL_PROCESSOR_SECRET=

# Development-only flags.
ENABLE_WHATSAPP_DEV_SIMULATOR=false
ENABLE_TELEGRAM_DEV_SIMULATOR=false
TRUSTKAKI_RUN_DB_INTEGRATION=0

# Optional: allows the slow 4-message Full Agent Replay in production.
# Keep unset for judge/demo deployment; Quick Demo is the primary production path.
ENABLE_FULL_AGENT_REPLAY=false
